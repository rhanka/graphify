{
  "name": "graphifyy",
  "version": "0.4.33",
  "description": "AI coding assistant skill (Claude Code, Codex, Gemini CLI, GitHub Copilot CLI, Aider, OpenCode, OpenClaw) - turn any folder of code, docs, papers, images, or audio/video transcripts into a queryable knowledge graph",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "graphify": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src/skills"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "test:serve": "vitest run tests/serve.test.ts",
    "test:smoke": "./scripts/smoke-test.sh",
    "test:pipeline": "vitest run tests/pipeline.test.ts",
    "test:all": "vitest run && npm run test:smoke",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "claude",
    "claude-code",
    "codex",
    "gemini",
    "gemini-cli",
    "copilot",
    "copilot-cli",
    "aider",
    "opencode",
    "knowledge-graph",
    "rag",
    "graphrag",
    "obsidian",
    "community-detection",
    "tree-sitter",
    "louvain",
    "llm",
    "audio",
    "video",
    "whisper",
    "youtube",
    "ocr",
    "mistral-ocr",
    "pdf"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rhanka/graphify.git"
  },
  "homepage": "https://github.com/rhanka/graphify",
  "bugs": {
    "url": "https://github.com/rhanka/graphify/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "csv-parse": "^6.2.1",
    "graphology": "^0.25.4",
    "graphology-communities-louvain": "^2.0.1",
    "graphology-metrics": "^2.1.0",
    "graphology-shortest-path": "^2.1.0",
    "graphology-types": "^0.24.7",
    "mistral-ocr": "^0.1.0",
    "web-tree-sitter": "^0.26.8",
    "yaml": "^2.8.3"
  },
  "optionalDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chokidar": "^4.0.0",
    "exceljs": "^4.4.0",
    "faster-whisper-ts": "^1.2.1",
    "mammoth": "^1.8.0",
    "neo4j-driver": "^5.27.0",
    "pdf-parse": "^1.1.1",
    "tree-sitter-c": "^0.24.1",
    "tree-sitter-c-sharp": "^0.23.1",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-elixir": "^0.3.5",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-julia": "^0.23.1",
    "tree-sitter-kotlin": "^0.3.8",
    "tree-sitter-lua": "^2.1.3",
    "tree-sitter-objc": "^3.0.2",
    "tree-sitter-php": "^0.24.2",
    "tree-sitter-powershell": "^0.26.3",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-ruby": "^0.23.1",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-scala": "^0.24.0",
    "tree-sitter-swift": "^0.7.1",
    "tree-sitter-typescript": "^0.23.2",
    "tree-sitter-zig": "^0.2.0",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
